{
  "name": "portfolio",
  "version": "0.1.22",
  "private": true,
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:stories": "node scripts/check-stories.mjs",
    "format": "biome format --write",
    "format:check": "biome format",
    "type-check": "tsc --noEmit",
    "prerender:mermaid": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/prerender-mermaid.ts",
    "generate:tokens": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/generate-tokens.ts",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:diff-coverage": "node scripts/check-diff-coverage.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "release": "commit-and-tag-version",
    "release:first": "commit-and-tag-version --first-release",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "release:patch": "commit-and-tag-version --release-as patch"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.7",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "github-slugger": "2.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.2.0",
    "lucide-react": "1.23.0",
    "next": "^16.1.6",
    "next-themes": "0.4.6",
    "radix-ui": "1.6.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "6.0.0",
    "remark-frontmatter": "^5.0.0",
    "shiki": "^4.2.0",
    "tailwind-merge": "3.6.0",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/nextjs": "10.4.6",
    "@tailwindcss/postcss": "4.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/mdx": "2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "commit-and-tag-version": "^12.6.1",
    "dotenv": "^17.2.3",
    "hast-util-to-html": "9.0.5",
    "husky": "^9",
    "jsdom": "^29.1.1",
    "mermaid-isomorphic": "^3.1.0",
    "playwright": "^1.60.0",
    "postcss": "8.5.16",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "storybook": "10.4.6",
    "tailwindcss": "4.3.2",
    "typescript": "^5",
    "unified": "11.0.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
