flowchart TB
  subgraph s_plan["Plan"]
    explore["<b>explore</b><br/>capture requirements, size the work"]
    propose["<b>propose</b><br/>turn intent into a contract"]
  end
  subgraph s_build["Build"]
    implement["<b>implement</b><br/>build one task, test-first"]
  end
  subgraph s_verify["Verify"]
    validate["<b>validate</b><br/>stop trusting one perspective"]
    review["<b>review-and-ship</b><br/>rule on findings, ship inline"]
    learn["<b>learn-from-reports</b><br/>never the same mistake twice"]
  end
  subgraph s_ship["Ship"]
    audit["<b>validate-impl</b><br/>final spec-completion audit"]
  end
  explore --> propose --> implement --> validate --> review --> learn --> audit

  classDef planNode   fill:#0b2733,stroke:#0ea5e9,stroke-width:2px,color:#e2e8f0;
  classDef buildNode  fill:#1a2b08,stroke:#84cc16,stroke-width:2px,color:#e2e8f0;
  classDef verifyNode fill:#241033,stroke:#a855f7,stroke-width:2px,color:#e2e8f0;
  classDef shipNode   fill:#33200a,stroke:#f97316,stroke-width:2px,color:#e2e8f0;
  class explore,propose planNode;
  class implement buildNode;
  class validate,review,learn verifyNode;
  class audit shipNode;

  style s_plan   fill:#0a1118,stroke:#0ea5e9,stroke-width:1px,color:#e2e8f0;
  style s_build  fill:#0a1118,stroke:#84cc16,stroke-width:1px,color:#e2e8f0;
  style s_verify fill:#0a1118,stroke:#a855f7,stroke-width:1px,color:#e2e8f0;
  style s_ship   fill:#0a1118,stroke:#f97316,stroke-width:1px,color:#e2e8f0;
